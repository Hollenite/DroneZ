{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "worktree": {
    "symlinkDirectories": []
  },
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/on_worktree_create.sh",
            "timeout": 30,
            "statusMessage": "Recording worktree creation"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/on_worktree_remove.sh",
            "timeout": 30,
            "statusMessage": "Recording worktree removal"
          }
        ]
      }
    ]
  }
}
