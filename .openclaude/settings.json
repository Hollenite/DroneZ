{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .openclaude/scripts/create_worktree.sh",
            "timeout": 120,
            "statusMessage": "Creating OpenClaude worktree"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .openclaude/scripts/remove_worktree.sh",
            "timeout": 120,
            "statusMessage": "Removing OpenClaude worktree"
          }
        ]
      }
    ]
  }
}
